<!DOCTYPE html>
<html>

<head>
  <title>Taco Recipes</title>
  <link rel="stylesheet" type="text/css" href="/styles/main.css">
</head>

<body>
  <h1>Taco Town 🌮</h1>

  <form action="/recipe" method="POST" class="buttons">
    <button type="submit" value="Chicken Taco" name="choice">🍗</button>
    <button type="submit" value="Beef Taco" name="choice">🥩</button>
    <button type="submit" value="Fish Taco" name="choice">🐟</button>
  </form>
  <div id="recipeContainer" class="hidden">

    <!-- If no recipe yet, show: -->
    <% if (!locals.recipe){%>
      <h2>Pick your favourite taco ingredient 👆</h2>
    <%}else{%>
    <!-- Else, show the recipe name e.g. <h2>Recipe name</h2>-->
      <h2><%= locals.recipe.name%></h2>
    <h3>Ingredients:</h3>
      <ul id="ingredientsList">

        <li> <%=locals.recipe.ingredients.protein.name%>, <%=locals.recipe.ingredients.protein.preparation%></li>
        <li><%=locals.recipe.ingredients.salsa.name%> <%=locals.recipe.ingredients.salsa.spiciness%></li>
        <li>
          <% locals.recipe.ingredients.toppings.forEach(top => { %>
          <div>
          <%=top.quantity%> of <%=top.name%>
          </div>
          <% })%>
        </li>
      </ul>
    <%}%>


  </div>
</body>

</html>